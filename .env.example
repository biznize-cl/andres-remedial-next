# Copy this file to `.env.local` and fill in your values.

# --- Public values (NEXT_PUBLIC_*) — these ARE embedded in the page. ---

# Your online booking embed URL (Cliniko / Halaxy / Calendly, etc.).
# Leave unset to show the "call to book" fallback card.
# Example: https://yourclinic.au2.cliniko.com/bookings?embedded=true
NEXT_PUBLIC_BOOKING_URL=

# Optional: override the address used for the contact map pin.
# Defaults to the clinic address in lib/content.ts when unset.
# NEXT_PUBLIC_MAP_QUERY=12 Esplanade, Mount Martha VIC 3934


# --- Server-only secrets — NEVER prefixed with NEXT_PUBLIC, so they stay   ---
# --- on the server and out of the browser bundle.                          ---

# Google Reviews. Leave BOTH unset to show curated testimonials instead.
#   1. Create a key in Google Cloud → APIs & Services, enable "Places API (New)".
#   2. Restrict the key (HTTP referrers / IP) so it can't be abused.
#   3. Find your Place ID with Google's Place ID Finder:
#      https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
